# 환경 변수 예시 파일
# 로컬 개발: .env.local 파일을 생성하고 개발용 값들을 설정하세요
# 프로덕션: Vercel Dashboard에서 환경 변수를 설정하세요 (소스 코드에 포함하지 마세요)

# ===== 개발 환경 (로컬) =====
# API 서버 URL (백엔드)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket 서버 URL
NEXT_PUBLIC_WS_URL=http://localhost:8080

# 프론트엔드 URL (공유 링크 생성용)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# 로컬 네트워크 테스트용 (모바일 테스트 등)
# NEXT_PUBLIC_WS_NET=http://192.168.x.x:8080


# ===== 프로덕션 환경 (Vercel) =====
# Vercel Dashboard > Settings > Environment Variables 에서 설정:
# NEXT_PUBLIC_API_URL=<your-production-api-url>
# NEXT_PUBLIC_WS_URL=<your-production-ws-url>
# NEXT_PUBLIC_FRONTEND_URL=<your-vercel-app-url>
